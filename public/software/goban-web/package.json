{
  "name": "goban-web",
  "version": "0.1.0",
  "description": "A Web Component for playing the game of Go, with Sabaki-inspired visuals.",
  "type": "module",
  "main": "dist/goban-web.js",
  "module": "dist/goban-web.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/goban-web.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json && vite build && vite build --config vite.demo.config.ts",
    "preview": "vite preview --config vite.demo.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "node scripts/release.mjs"
  },
  "devDependencies": {
    "jsdom": "^25.0.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  }
}
